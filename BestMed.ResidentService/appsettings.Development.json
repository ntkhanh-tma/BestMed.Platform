{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "BestMed": "Debug"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "ConnectionStrings": {
    "residentdb": "Server=YOUR_SERVER;Database=sqldb-bmp-residents-dev;User Id=YOUR_USER;Password=YOUR_PASSWORD;Encrypt=True;TrustServerCertificate=False;",
    "residentdb-readonly": "Server=YOUR_SERVER;Database=sqldb-bmp-residents-dev;User Id=YOUR_USER;Password=YOUR_PASSWORD;Encrypt=True;TrustServerCertificate=False;",
    "servicebus": "Endpoint=YOUR_ENDPOINT;SharedAccessKeyName=YOUR_KEY_NAME;SharedAccessKey=YOUR_KEY;"
  }
}
