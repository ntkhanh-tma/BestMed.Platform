{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Error",
      "Override": {
        "Microsoft.AspNetCore": "Error",
        "System.Net.Http": "Error"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Error",
      "Microsoft.AspNetCore": "Error"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "BestMed",
    "Audience": "BestMed.Services",
    "Key": "CHANGE-THIS-TO-A-SECURE-KEY-AT-LEAST-32-CHARS!"
  },
  "IdentityServer": {
    "BaseUrl": "https://your-identity-server.example.com",
    "ClientId": "bestmed.homecare.mobile",
    "Scope": "api"
  }
}
